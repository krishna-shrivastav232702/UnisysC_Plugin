void foo(int param) {

  switch (param) {
    case 0:
      break;
    case 1:
      break
    default:       // OK
      break;
  }

  switch (param) {     // Noncompliant
    case 1:
      break;
  }

  switch (param) {
    case 0:
      break; 
    default:          //Noncompliant
      break;
    case 1:
      break;
  }

}
