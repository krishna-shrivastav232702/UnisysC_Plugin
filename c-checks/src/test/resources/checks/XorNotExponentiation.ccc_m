void test_xor_operator() {
    int a = 10;
    int b = 2;
    int c;

    c = 10 ^ 2;          // Noncompliant
    c = a ^ 2;           // Noncompliant
    c = 10 ^ b;          // Noncompliant
    c = 100L ^ a;        // Noncompliant
    
    c = a ^ b;           // OK 
    
    c = 0x0A ^ 0x02;     // OK
    c = a ^ 0x02;        // OK
    
    c = 012 ^ a;         // OK 
    
    c = a ^ 0;           // OK
}