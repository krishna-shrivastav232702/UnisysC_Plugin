void test() {
    int a = 1;
    int b = 1;
    int c = 1;
    int result;

    if (a && b) {              // OK 
        result = 1;
    }

    if (a || b) {              // OK 
        result = 1;
    }

    if (a & b) {               // Noncompliant 
        result = 1;
    }

    if (a | b) {               // Noncompliant 
        result = 1;
    }

    if (a ^ b) {               // Noncompliant 
        result = 1;
    }

    if (a > 0 && b > 0) {      // OK 
        result = 1;
    }

    while (a & b) {            // Noncompliant 
        a = a - 1;
    }

    while (a && b) {           // OK
        a = a - 1;
    }

    result = a & b;            // OK 
    result = a | b;            // OK 
    result = a ^ b;            // OK
}