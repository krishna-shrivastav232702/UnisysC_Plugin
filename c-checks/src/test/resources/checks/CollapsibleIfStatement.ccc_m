void test_collapsible_if() {
  
  if (condition1)
    if (condition2) { // Noncompliant
      doSomething();
    }

  if (1) {
  } else if (condition1) {
    if (condition2) { // Noncompliant
      doSomething();
    }
  }

  if (condition1 && condition2) { // OK
    doSomething();
  }

  if (condition1) {
    if (condition2) { // OK
      doSomething();
    }
  } else {
    doOther();
  }

  if (condition1) {
    if (condition2) { // OK
      doSomething();
    } else {
      doOther();
    }
  }

  if (condition1) {
    int x = 1; // OK 
    if (condition2) {
      doSomething();
    }
  }

  if (condition1) {
    if (condition2) { // OK 
      doSomething();
    }
    doSomethingElse();
  }

  if (condition1) {
    while (condition2) { // OK
      if (condition3) { 
        doSomething();
      }
    }
  }

  if (condition1) {
    // OK 
  }
}